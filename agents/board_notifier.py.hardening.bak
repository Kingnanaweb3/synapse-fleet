import asyncio
import json
import os
import re
import sys
from datetime import datetime

import yaml
from dotenv import load_dotenv

from band import Agent, run_with_graceful_shutdown
from band.core.simple_adapter import SimpleAdapter
from band.core.protocols import AgentToolsProtocol
from band.core.types import PlatformMessage

load_dotenv()

with open(os.path.join(os.path.dirname(os.path.dirname(__file__)), "agent_config.yaml")) as f:
    CONFIG = yaml.safe_load(f)

AGENT_ID = CONFIG["board_notifier"]["agent_id"]
API_KEY  = CONFIG["board_notifier"]["api_key"]
ROOM_ID  = os.getenv("BAND_ROOM_ID")

sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))
from agents.llm import chat

SYSTEM_PROMPT = """You are Board Notifier, the executive communication agent for Synapse Fleet.

Your job:
1. Receive the remediation playbook from Remediation Architect
2. Synthesize ALL upstream agent outputs into a formal executive board memo
3. The memo must be clear, professional, and suitable for C-suite and board review
4. Flag the package for mandatory human sign-off

Respond with ONLY this JSON, no other text:
{
  "event": "board_memo_pending_approval",
  "requires_human_signoff": true,
  "memo": {
    "classification": "CONFIDENTIAL — BOARD USE ONLY",
    "to": "Board of Directors & Executive Leadership Team",
    "from": "Synapse Fleet Compliance Intelligence System",
    "date": "<today's date>",
    "subject": "<regulation name> Compliance Risk — Executive Action Required",
    "executive_summary": "<3-4 sentence summary of the entire situation>",
    "financial_exposure": {
      "maximum_penalty_eur": <number>,
      "expected_penalty_eur": <number>,
      "remediation_cost_eur": <number>,
      "risk_ratio": "<X:1>"
    },
    "compliance_status": {
      "total_obligations": <number>,
      "compliant": <number>,
      "partially_compliant": <number>,
      "non_compliant": <number>,
      "overall_risk": "<CRITICAL|HIGH|MEDIUM|LOW>"
    },
    "top_3_risks": ["<risk 1>", "<risk 2>", "<risk 3>"],
    "immediate_actions": ["<action 1>", "<action 2>", "<action 3>"],
    "recommended_board_resolution": "<specific resolution the board should pass>",
    "next_review_date": "<30 days from today>",
    "prepared_by": "Synapse Fleet AI Compliance System",
    "approved_by": "PENDING HUMAN SIGN-OFF"
  },
  "summary": "<2-3 sentence description of what this memo contains and why sign-off is needed>"
}"""


class BoardNotifierAdapter(SimpleAdapter[list]):

    def __init__(self):
        super().__init__()
        self._processed_messages = set()

    async def on_started(self, agent_name: str, agent_description: str) -> None:
        await super().on_started(agent_name, agent_description)
        print(f"[Board Notifier] Agent started: {agent_name}")

    async def on_message(
        self,
        msg: PlatformMessage,
        tools: AgentToolsProtocol,
        history: list,
        participants_msg: str | None,
        contacts_msg: str | None,
        *,
        is_session_bootstrap: bool,
        room_id: str,
    ) -> None:
        content = msg.content.strip()

        # Deduplication
        if msg.id in self._processed_messages:
            print(f"[Board Notifier] Skipping duplicate message {msg.id}")
            return
        self._processed_messages.add(msg.id)

        if AGENT_ID not in content and "board-notifier" not in content.lower() and "board notifier" not in content.lower():
            return

        print(f"[Board Notifier] Received message {msg.id}...")

        # Extract remediation JSON
        json_match = re.search(r'\{[^{}]*"event"\s*:\s*"remediation_plan_ready".*?\}', content, re.DOTALL)
        remediation_data = None
        if json_match:
            try:
                remediation_data = json.loads(json_match.group())
                print(f"[Board Notifier] Parsed remediation plan for: {remediation_data.get('company')}")
            except json.JSONDecodeError:
                print(f"[Board Notifier] Could not parse remediation JSON")

        today = datetime.now().strftime("%B %d, %Y")

        messages = [
            {"role": "system", "content": SYSTEM_PROMPT},
            {"role": "system", "content": f"Today's date: {today}"},
            {"role": "system", "content": f"REMEDIATION PLAN AND FULL CONTEXT:\n{json.dumps(remediation_data, indent=2) if remediation_data else content}"},
            {"role": "user", "content": "Prepare the executive board memo and flag for human sign-off."}
        ]

        print(f"[Board Notifier] Calling Groq...")
        raw_reply = (await chat("board_notifier", messages, max_tokens=2000, temperature=0.1)).strip()
        raw_reply = raw_reply.replace("```json", "").replace("```", "").strip()

        reply = (
            f"🚨 **BOARD MEMO — REQUIRES HUMAN SIGN-OFF** 🚨\n\n"
            f"```json\n{raw_reply}\n```\n\n"
            f"---\n"
            f"@kingnana This compliance package requires your approval before dispatch. "
            f"Please review and reply **APPROVED** or **REJECTED** with any comments."
        )

        print(f"[Board Notifier] Sending board memo to Band, mentioning human for approval...")
        await tools.send_message(reply, mentions=["@kingnana"])
        import sys, os; sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__)))); from agents.ui_reporter import report_event
        report_event("board_notifier", "board_memo_pending_approval", "Board memo ready — requires human sign-off", reply)
        print(f"[Board Notifier] ✅ Board memo delivered. Awaiting human sign-off.")


async def main():
    print(f"[Board Notifier] Starting — agent {AGENT_ID}")
    print(f"[Board Notifier] Room: {ROOM_ID}")

    adapter = BoardNotifierAdapter()
    agent = Agent.create(
        adapter=adapter,
        agent_id=AGENT_ID,
        api_key=API_KEY,
    )

    print("[Board Notifier] Connected to Band. Listening...")
    await run_with_graceful_shutdown(agent, timeout=30.0)


if __name__ == "__main__":
    asyncio.run(main())
