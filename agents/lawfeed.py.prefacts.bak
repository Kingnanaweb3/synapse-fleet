import asyncio
import json
import os
import sys

import yaml
from dotenv import load_dotenv

from band import Agent, run_with_graceful_shutdown
from band.core.simple_adapter import SimpleAdapter
from band.core.protocols import AgentToolsProtocol
from band.core.types import PlatformMessage

sys.path.append(os.path.dirname(os.path.dirname(os.path.abspath(__file__))))
from data_sources.regulations import fetch_regulation, list_available_regulations

load_dotenv()

with open(os.path.join(os.path.dirname(os.path.dirname(__file__)), "agent_config.yaml")) as f:
    CONFIG = yaml.safe_load(f)

AGENT_ID = CONFIG["lawfeed"]["agent_id"]
API_KEY  = CONFIG["lawfeed"]["api_key"]
ROOM_ID  = os.getenv("BAND_ROOM_ID")

SIBLING_AGENTS = {
    "exposure-analyzer":     CONFIG["exposure_analyzer"]["agent_id"],
    "risk-assessor":         CONFIG["risk_assessor"]["agent_id"],
    "remediation-architect": CONFIG["remediation_architect"]["agent_id"],
    "board-notifier":        CONFIG["board_notifier"]["agent_id"],
}

sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))
from agents.llm import chat

SYSTEM_PROMPT = """You are LawFeed, the regulatory ingestion agent for Synapse Fleet.
Your job: analyze regulation text and extract structured compliance data.
Respond with ONLY this JSON, no other text before or after:
{
  "event": "regulation_ingested",
  "regulation_key": "<key>",
  "regulation_name": "<full name>",
  "celex": "<celex number>",
  "obligations": ["<obligation 1>", "<obligation 2>", "<obligation 3>"],
  "affected_domains": ["<domain 1>", "<domain 2>"],
  "compliance_deadline": "<deadline or Already in force>",
  "max_penalty_eur": <number>,
  "max_penalty_pct_turnover": <number>,
  "severity": "<Critical|High|Medium>",
  "summary": "<2-3 sentence plain English summary>"
}"""


class LawFeedAdapter(SimpleAdapter[list]):

    def __init__(self):
        super().__init__()
        self._room_initialized = False

    async def on_started(self, agent_name: str, agent_description: str) -> None:
        await super().on_started(agent_name, agent_description)
        print(f"[LawFeed] Agent started: {agent_name}")

    async def on_message(
        self,
        msg: PlatformMessage,
        tools: AgentToolsProtocol,
        history: list,
        participants_msg: str | None,
        contacts_msg: str | None,
        *,
        is_session_bootstrap: bool,
        room_id: str,
    ) -> None:
        content = msg.content.strip()

        if not self._room_initialized:
            await self._initialize_room(tools, room_id)
            self._room_initialized = True

        if AGENT_ID not in content and "lawfeed" not in content.lower():
            return

        print(f"[LawFeed] Received: {content[:120]}...")

        regulation_key = None
        for key in ["GDPR", "EU_AI_ACT", "DORA"]:
            if key.lower().replace("_", " ") in content.lower() or key.lower() in content.lower():
                regulation_key = key
                break

        regulation_data = None
        if regulation_key:
            print(f"[LawFeed] Fetching {regulation_key} from EUR-Lex...")
            regulation_data = fetch_regulation(regulation_key)
            if regulation_data:
                print(f"[LawFeed] Fetched {len(regulation_data.get('raw_text', ''))} chars")

        messages = [{"role": "system", "content": SYSTEM_PROMPT}]

        if regulation_data:
            messages.append({
                "role": "system",
                "content": (
                    f"Regulation: {regulation_data['name']}\n"
                    f"CELEX: {regulation_data['celex']}\n"
                    f"Max penalty: EUR {regulation_data['max_penalty_eur']:,} "
                    f"or {regulation_data['max_penalty_pct']}% of global turnover\n"
                    f"Text excerpt:\n{regulation_data['raw_text'][:4000]}"
                )
            })

        for h in []:
            if isinstance(h, dict) and "role" in h and "content" in h:
                messages.append({"role": h["role"], "content": h["content"]})

        messages.append({"role": "user", "content": content})

        print(f"[LawFeed] Calling Groq...")
        raw_reply = (await chat("lawfeed", messages, max_tokens=1500, temperature=0.1)).strip()
        raw_reply = raw_reply.replace("```json", "").replace("```", "").strip()

        reply = (
            f"**LawFeed — Regulation Ingested**\n\n"
            f"```json\n{raw_reply}\n```\n\n"
            f"@exposure-analyzer please analyze our compliance exposure against this regulation."
        )

        print(f"[LawFeed] Sending to Band room, mentioning exposure-analyzer...")
        await tools.send_message(reply, mentions=["@kingnana/exposure-analyzer"])
        import sys, os; sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__)))); from agents.ui_reporter import report_event
        report_event("lawfeed", "regulation_ingested", f"Regulation ingested — {regulation_key or "unknown"}", reply)
        print(f"[LawFeed] Done.")

    async def _initialize_room(self, tools: AgentToolsProtocol, room_id: str) -> None:
        print(f"[LawFeed] Initializing room — adding sibling agents...")
        for name, agent_id in SIBLING_AGENTS.items():
            try:
                await tools.add_participant(agent_id)
                print(f"[LawFeed] Added {name}")
            except Exception as e:
                print(f"[LawFeed] {name} already in room or error: {e}")


async def main():
    print(f"[LawFeed] Starting — agent {AGENT_ID}")
    print(f"[LawFeed] Room: {ROOM_ID}")

    adapter = LawFeedAdapter()
    agent = Agent.create(
        adapter=adapter,
        agent_id=AGENT_ID,
        api_key=API_KEY,
    )

    print("[LawFeed] Connected to Band. Listening...")
    await run_with_graceful_shutdown(agent, timeout=30.0)


if __name__ == "__main__":
    asyncio.run(main())
