import asyncio
import json
import os
import re
import sys

import yaml
from dotenv import load_dotenv
from openai import AsyncOpenAI

from band import Agent, run_with_graceful_shutdown
from band.core.simple_adapter import SimpleAdapter
from band.core.protocols import AgentToolsProtocol
from band.core.types import PlatformMessage

load_dotenv()

with open(os.path.join(os.path.dirname(os.path.dirname(__file__)), "agent_config.yaml")) as f:
    CONFIG = yaml.safe_load(f)

AGENT_ID = CONFIG["remediation_architect"]["agent_id"]
API_KEY  = CONFIG["remediation_architect"]["api_key"]
ROOM_ID  = os.getenv("BAND_ROOM_ID")

client = AsyncOpenAI(
    base_url="https://openrouter.ai/api/v1",
    api_key=os.getenv("OPENROUTER_API_KEY"),
)

SYSTEM_PROMPT = """You are Remediation Architect, a compliance remediation planning agent for Synapse Fleet.

Your job:
1. Receive a financial risk quantification report from Risk Assessor
2. Generate a concrete, actionable remediation playbook
3. Prioritize actions by urgency and impact
4. Assign owners, timelines, and success criteria for each action

Respond with ONLY this JSON, no other text:
{
  "event": "remediation_plan_ready",
  "company": "<company name>",
  "regulation_key": "<key>",
  "total_actions": <number>,
  "estimated_completion_days": <number>,
  "playbook": [
    {
      "priority": "<IMMEDIATE|SHORT_TERM|MEDIUM_TERM|LONG_TERM>",
      "action": "<specific action title>",
      "description": "<detailed description of what needs to be done>",
      "owner": "<department or role responsible>",
      "timeline_days": <number>,
      "success_criteria": "<how to verify this is done>",
      "estimated_cost_eur": <number>
    }
  ],
  "quick_wins": ["<action that can be done in under 7 days>", "<action 2>"],
  "critical_path": ["<step 1>", "<step 2>", "<step 3>"],
  "total_estimated_cost_eur": <number>,
  "summary": "<3-4 sentence executive summary of the remediation plan>"
}"""


class RemediationArchitectAdapter(SimpleAdapter[list]):

    def __init__(self):
        super().__init__()
        self._processed_messages = set()

    async def on_started(self, agent_name: str, agent_description: str) -> None:
        await super().on_started(agent_name, agent_description)
        print(f"[Remediation Architect] Agent started: {agent_name}")

    async def on_message(
        self,
        msg: PlatformMessage,
        tools: AgentToolsProtocol,
        history: list,
        participants_msg: str | None,
        contacts_msg: str | None,
        *,
        is_session_bootstrap: bool,
        room_id: str,
    ) -> None:
        content = msg.content.strip()

        # Deduplication
        if msg.id in self._processed_messages:
            print(f"[Remediation Architect] Skipping duplicate message {msg.id}")
            return
        self._processed_messages.add(msg.id)

        if AGENT_ID not in content and "remediation-architect" not in content.lower() and "remediation architect" not in content.lower():
            return

        print(f"[Remediation Architect] Received message {msg.id}...")

        # Extract risk JSON from message
        json_match = re.search(r'\{[^{}]*"event"\s*:\s*"risk_quantified".*?\}', content, re.DOTALL)
        risk_data = None
        if json_match:
            try:
                risk_data = json.loads(json_match.group())
                print(f"[Remediation Architect] Parsed risk report for: {risk_data.get('company')}")
            except json.JSONDecodeError:
                print(f"[Remediation Architect] Could not parse risk JSON")

        messages = [
            {"role": "system", "content": SYSTEM_PROMPT},
            {"role": "system", "content": f"RISK ASSESSMENT:\n{json.dumps(risk_data, indent=2) if risk_data else content}"},
            {"role": "user", "content": "Generate a comprehensive remediation playbook for this compliance risk."}
        ]

        print(f"[Remediation Architect] Calling OpenRouter...")
        response = await client.chat.completions.create(
            model="anthropic/claude-sonnet-4-5",
            messages=messages,
            max_tokens=2500,
            temperature=0.1,
        )

        raw_reply = response.choices[0].message.content.strip()
        raw_reply = raw_reply.replace("```json", "").replace("```", "").strip()

        reply = (
            f"**Remediation Architect — Remediation Playbook**\n\n"
            f"```json\n{raw_reply}\n```\n\n"
            f"@board-notifier please prepare the executive board memo and flag for human approval."
        )

        print(f"[Remediation Architect] Sending to Band, mentioning board-notifier...")
        await tools.send_message(reply, mentions=["@kingnana/board-notifier"])
        import sys, os; sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__)))); from agents.ui_reporter import report_event
        report_event("remediation_architect", "remediation_plan_ready", "Remediation playbook generated", reply)
        print(f"[Remediation Architect] Done.")


async def main():
    print(f"[Remediation Architect] Starting — agent {AGENT_ID}")
    print(f"[Remediation Architect] Room: {ROOM_ID}")

    adapter = RemediationArchitectAdapter()
    agent = Agent.create(
        adapter=adapter,
        agent_id=AGENT_ID,
        api_key=API_KEY,
    )

    print("[Remediation Architect] Connected to Band. Listening...")
    await run_with_graceful_shutdown(agent, timeout=30.0)


if __name__ == "__main__":
    asyncio.run(main())
